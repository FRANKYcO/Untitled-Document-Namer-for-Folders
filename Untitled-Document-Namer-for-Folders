/**
 * Extracts the folder ID from a Google Drive folder URL.
 */
function extractFolderId_(folderUrlOrId) {
  const input = String(folderUrlOrId || '').trim();

  if (
    !input ||
    input === 'PASTE_YOUR_GOOGLE_DRIVE_FOLDER_URL_HERE'
  ) {
    throw new Error(
      'Paste your Google Drive folder URL into SETTINGS.FOLDER_URL.'
    );
  }

  const folderMatch = input.match(
    /\/folders\/([a-zA-Z0-9_-]+)/
  );

  const folderId = folderMatch ?
    folderMatch[1] :
    input;

  if (!/^[a-zA-Z0-9_-]{10,}$/.test(folderId)) {
    throw new Error(
      'The Google Drive folder URL or folder ID is invalid.'
    );
  }

  return folderId;
}
